<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0" type="device">
  <diagram id="ecomind-arch" name="EcoMind Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1240" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="EcoMind — AI Personal Life Companion · System Architecture (Hybrid-Privacy Build)" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#1B1B2F;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Raw personal data stays on-device (encrypted); only irreversible embeddings reach the cloud. Every entry passes a 3-tier safety classifier FIRST." style="text;html=1;fontSize=13;fontStyle=2;align=center;verticalAlign=middle;fontColor=#616161;" vertex="1" parent="1">
          <mxGeometry x="40" y="58" width="1520" height="24" as="geometry" />
        </mxCell>

        <!-- ============ ON-DEVICE ZONE (big container) ============ -->
        <mxCell id="zone-device" value="ON-DEVICE  (raw data never leaves the phone in readable form)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;dashed=1;dashPattern=8 4;verticalAlign=top;fontStyle=1;fontColor=#1B5E20;fontSize=13;arcSize=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="95" width="1520" height="230" as="geometry" />
        </mxCell>

        <!-- Client apps -->
        <mxCell id="c-mobile" value="Mobile App — Flutter (iOS / Android)&#10;Dark-mode, mobile-first, voice-first&#10;AI Home / dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="135" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c-web" value="Web App&#10;(Dashboard / AI Home)&#10;[V2 — future]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#90A4AE;fontSize=12;dashed=1;fontColor=#607D8B;" vertex="1" parent="1">
          <mxGeometry x="330" y="135" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c-voice" value="Voice Capture&#10;Continuous listening →&#10;Whisper STT (audio discarded&#10;after transcription)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="550" y="135" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c-emergency" value="Emergency / Crisis Screen&#10;Permanent help button on every screen&#10;One-tap: iCall · Vandrevala helplines&#10;&#39;Not a therapist&#39; disclaimer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1090" y="135" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c-embed" value="On-device Embedding + Personas&#10;Encrypt query → send embedding only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="810" y="135" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- On-device encrypted store -->
        <mxCell id="d-local" value="On-Device Encrypted Store — SQLite (encrypted) + iOS Keychain / Android Keystore&#10;Raw journal text · voice transcripts · calendar &amp; email snippets · goals, habits, notes, docs · encryption keys" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="70" y="235" width="980" height="70" as="geometry" />
        </mxCell>
        <mxCell id="safety-gate" value="① 3-TIER SAFETY CLASSIFIER&#10;Runs FIRST on every entry&#10;L1 normal · L2 concern · L3 crisis&#10;(clinical-advisor approved)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=12;fontStyle=1;fontColor=#B71C1C;" vertex="1" parent="1">
          <mxGeometry x="1090" y="235" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- ============ PRIVACY BOUNDARY ============ -->
        <mxCell id="boundary" value="🔒  PRIVACY BOUNDARY  —  only encrypted embeddings + account/subscription state cross this line.  No decrypted personal content, no audio, no AI query logs with content.  (DPDP-compliant · AWS Mumbai ap-south-1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=12;fontStyle=1;fontColor=#F57F17;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="1520" height="34" as="geometry" />
        </mxCell>

        <!-- ============ CLOUD ZONE ============ -->
